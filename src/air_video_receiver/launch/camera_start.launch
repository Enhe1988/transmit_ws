<launch>
    <arg name="record_bag"     default="false" />
    <arg name="time_offset_ms" default="0.0" />

    <node pkg="air_video_receiver" type="h265_node" name="h265_node" output="screen">
        <param name="time_offset_ms" value="$(arg time_offset_ms)" />
    </node>

    <node pkg="rqt_image_view" type="rqt_image_view" name="rqt_viewer"
          args="/camera/image_raw" output="log" />

    <node pkg="rosbag" type="record" name="rosbag_record"
          args="-o $(find air_video_receiver)/bags/camera_data /camera/image_raw"
          if="$(arg record_bag)"
          output="screen" />
</launch>
